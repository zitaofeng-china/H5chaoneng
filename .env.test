# 测试环境配置
NODE_ENV=test

# API 基础 URL（测试服务器地址）
VITE_API_BASE_URL=https://test-api.example.com/api

# 应用端口
VITE_PORT=8080

# 是否自动打开浏览器
VITE_OPEN=true

# 是否开启 Mock 数据
VITE_USE_MOCK=false

# 是否开启请求日志
VITE_ENABLE_REQUEST_LOG=true

# 是否开启响应日志
VITE_ENABLE_RESPONSE_LOG=true

# 是否开启错误上报
VITE_ENABLE_ERROR_REPORT=true

# 错误上报地址
VITE_ERROR_REPORT_URL=https://test-error.example.com/report

# 是否开启性能监控
VITE_ENABLE_PERFORMANCE=true

# 性能监控地址
VITE_PERFORMANCE_URL=https://test-performance.example.com/report

# 是否开启 HTTPS
VITE_HTTPS=true

# 测试环境特有配置
VITE_TEST_MODE=true

# 是否显示调试信息
VITE_SHOW_DEBUG=true
