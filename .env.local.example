# 本地环境配置示例
# 复制此文件为 .env.local 并修改为你的本地配置
# .env.local 不会被 Git 跟踪，可以包含敏感信息

# API 基础 URL（你的本地后端地址）
VITE_API_BASE_URL=http://localhost:3000/api

# 应用端口
VITE_PORT=8080

# 是否自动打开浏览器
VITE_OPEN=true

# 是否开启 Mock 数据
VITE_USE_MOCK=false

# 是否开启请求日志
VITE_ENABLE_REQUEST_LOG=true

# 是否开启响应日志
VITE_ENABLE_RESPONSE_LOG=true

# 是否开启错误上报
VITE_ENABLE_ERROR_REPORT=false

# 是否开启性能监控
VITE_ENABLE_PERFORMANCE=false

# 个人开发配置
# VITE_CUSTOM_CONFIG=your_custom_value
